{
  "name": "coms-aha-heroes",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter=server dev",
    "build": "bun run --filter=@coms/shared build && bun run --filter=@coms/web build && bun run --filter=@coms/server build",
    "lint": "eslint .",
    "typecheck": "bun run --filter=* typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run --env-file=.env tsx packages/shared/src/db/seed/index.ts",
    "db:studio": "drizzle-kit studio",
    "generate:schemas": "bun run --filter=shared generate:schemas"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.0",
    "@elysiajs/eden": "^1.3.0",
    "@google-cloud/storage": "^7.19.0",
    "@googleapis/sheets": "^13.0.1",
    "@sinclair/typebox": "^0.34.0",
    "better-auth": "^1.5.6",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.0",
    "elysia": "^1.3.0",
    "postgres": "^3.4.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.5.4",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.20.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.25.0"
  },
  "trustedDependencies": [
    "esbuild"
  ]
}
