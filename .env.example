DATABASE_URL=postgresql://dev:dev@localhost:5433/coms_aha_heroes_dev

# COMS Portal SSO
PORTAL_ORIGIN=http://localhost:5173
PUBLIC_PORTAL_ORIGIN=http://localhost:5173
PORTAL_APP_SLUG=heroes
PUBLIC_APP_ORIGIN=http://localhost:3000
# Portal Cloud Run SA email — verifies inbound webhook Authorization: Bearer ID tokens (Rev 2 §03)
PORTAL_SERVICE_ACCOUNT_EMAIL=coms-portal-run-sa@coms-portal-prod.iam.gserviceaccount.com
# Heroes' own public URL — expected 'aud' claim when verifying portal-issued ID tokens (Rev 2 §03)
SELF_PUBLIC_URL=http://localhost:3000

# Google Sheets Sync
GOOGLE_SHEETS_SA_KEY=        # Service Account key JSON (base64-encoded) — or path to key file
GOOGLE_SHEET_ID_POINTS=      # Spreadsheet ID for points & redeem tabs
GOOGLE_SHEET_ID_EMPLOYEES=   # Spreadsheet ID for employee list tab
SHEET_TAB_EMPLOYEES=HEROES - Fulltime Staff
SHEET_TAB_BINTANG=Poin Bintang
SHEET_TAB_PENALTI=Poin Penalti
SHEET_TAB_POIN_AHA=Poin AHA
SHEET_TAB_REDEEM=Redeem Poin AHA
SHEET_SYNC_INTERVAL_MS=600000  # Sync interval in ms (default: 10 min)
