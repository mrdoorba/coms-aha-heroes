{
  "name": "@coms/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "i18n:compile": "paraglide-js compile --project ../../project.inlang --outdir ./src/lib/paraglide --strategy cookie preferredLanguage baseLocale --emit-ts-declarations",
    "build": "bun run i18n:compile && vite build",
    "preview": "vite preview",
    "typecheck": "bun run i18n:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@coms/server": "workspace:*",
    "@coms/shared": "workspace:*",
    "@elysiajs/eden": "^1.3.0",
    "@fontsource/manrope": "^5.1.1",
    "@inlang/paraglide-js": "^2.16.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.0",
    "google-auth-library": "^10.6.2",
    "jose": "^5.10.0",
    "layerchart": "^1.0.0",
    "lucide-svelte": "^0.460.0",
    "svelte-sonner": "^0.3.0",
    "sveltekit-superforms": "^2.22.0",
    "tailwind-merge": "^3.5.0",
    "typebox": "^1.1.23"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.0",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vite-pwa/sveltekit": "^0.6.0",
    "svelte": "^5.15.0",
    "svelte-adapter-bun": "^0.5.0",
    "svelte-check": "^4.1.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.0",
    "vite": "^6.0.0"
  }
}
